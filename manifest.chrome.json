{
  "manifest_version": 3,
  "name": "Bonusradar",
  "version": "0.4.0",
  "description": "Flags SAS EuroBonus partner shops in Sweden, Norway and Denmark as you browse, so you can shop via the portal and actually earn points.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://onlineshopping.loyaltykey.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/compat.js", "lib/match.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icons/icon-48.png", "96": "icons/icon-96.png" },
    "default_title": "Bonusradar"
  },
  "icons": { "48": "icons/icon-48.png", "96": "icons/icon-96.png" }
}
